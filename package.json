{
  "name": "vite-react-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/finalize-static-build.mjs",
    "preview": "vite preview",
    "lint:css": "stylelint \"src/**/*.css\" --fix --quiet",
    "lint:js": "eslint . --ext ts,tsx --report-unused-disable-directives",
    "lint:types": "tsc --noEmit",
    "check:css-vars": "node scripts/check-css-variables.js",
    "check:css-classes": "node scripts/check-css-classes.js",
    "lint": "bun run lint:types && bun run lint:js && bun run lint:css && bun run check:css-vars && bun run check:css-classes"
  },
  "devDependencies": {
    "typescript": "~6.0.2",
    "vite": "8.0.14"
  },
  "dependencies": {
    "@blinkdotnew/sdk": "^2.7.1",
    "@dnd-kit/core": "^6.3.1",
    "@eslint/js": "^10.0.1",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tailwindcss/vite": "4.1.13",
    "@tanstack/react-query": "5.101.0",
    "@tanstack/react-router": "1.170.11",
    "@tanstack/react-start": "1.168.19",
    "@vitejs/plugin-react": "5.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "framer-motion": "^12.42.2",
    "glob": "^13.0.6",
    "globals": "^17.7.0",
    "lucide-react": "^1.24.0",
    "pnpm": "9",
    "react-hook-form": "^7.81.0",
    "react-hot-toast": "^2.6.0",
    "react-responsive": "^10.0.1",
    "recharts": "^3.9.2",
    "sonner": "^2.0.7",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "4.1.13",
    "tw-animate-css": "^1.4.0",
    "typescript-eslint": "^8.63.0",
